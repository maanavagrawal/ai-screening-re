# Supabase project URL used by browser clients.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key used by browser clients for public reads where allowed.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Server-side only; never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key for server-side Vercel AI SDK calls.
ANTHROPIC_API_KEY=

# Twilio account SID for Verify. Server-side only.
TWILIO_ACCOUNT_SID=

# Twilio auth token for Verify. Server-side only.
TWILIO_AUTH_TOKEN=

# Twilio Verify service SID used only when requesting a showing.
TWILIO_VERIFY_SERVICE_SID=
