# Railway Postgres connection string. Railway sets this automatically when you add Postgres.
DATABASE_URL=

# Public app URL used to render magic links, share links, and QR codes.
NEXT_PUBLIC_APP_URL=

# Secret used by future signed-cookie/session hardening. Generate a long random value.
SESSION_SECRET=

# Anthropic API key for server-side Vercel AI SDK calls.
ANTHROPIC_API_KEY=

# Required ATTOM Data API key for server-side listing property fact lookup.
ATTOM_API_KEY=

# Required Google Places API key for server-side buyer area autocomplete.
GOOGLE_PLACES_API_KEY=

# Optional: force the intake next-question picker to call Anthropic on every answer.
# Leave blank for the faster deterministic picker; free-text extraction and lead briefs still use AI.
ENABLE_AI_INTAKE_NEXT=

# Twilio account SID for Verify. Server-side only.
TWILIO_ACCOUNT_SID=

# Twilio auth token for Verify. Server-side only.
TWILIO_AUTH_TOKEN=

# Twilio Verify service SID used only when requesting a showing.
TWILIO_VERIFY_SERVICE_SID=

# Resend API key for server-side setup magic links and transactional notifications.
RESEND_API_KEY=

# Verified Resend sender, e.g. "Memoir <noreply@yourdomain.com>".
EMAIL_FROM=

# Local/e2e switches. Leave blank in production.
DISABLE_AI=
DISABLE_TWILIO=

# Local-only auth bypass for setup. Leave blank in production.
ALLOW_DEV_AGENT_AUTH=
